{
  "templateId": "default",
  "description": "Happy path: user prompt activates pipeline, 3 reads in Phase A, stop advances",
  "events": [
    { "event": "user-prompt", "payload": { "prompt": "Fix the login bug in auth.js" } },
    { "event": "post-tool", "payload": { "tool_name": "Read", "tool_response": { "filePath": "auth.js" } } },
    { "event": "post-tool", "payload": { "tool_name": "Glob", "tool_response": { "pattern": "*.js" } } },
    { "event": "post-tool", "payload": { "tool_name": "Grep", "tool_response": { "pattern": "login" } } },
    { "event": "stop", "payload": {} }
  ]
}
