# pipeline-dashboard/.env — copy to .env and edit locally (gitignored)
#
# HARNESS_HOST
#   Default: 127.0.0.1 (loopback-only, safe local dev).
#   Set to 0.0.0.0 to expose on all interfaces (Docker, LAN). When you do,
#   you MUST also set HARNESS_TOKEN below — the server prints a warning
#   and mutating routes become exposed without it.
#HARNESS_HOST=127.0.0.1

# HARNESS_TOKEN
#   When unset, mutating API routes are unprotected (loopback is trusted).
#   When set, non-loopback requests must present the token via either
#     X-Harness-Token: <token>     (HTTP header)
#     ?token=<token>               (query param — used by WebSocket upgrade)
#   Loopback (127.0.0.1 / ::1) requests ALWAYS bypass the token check, so
#   local dev remains frictionless.
#
#   Pick a long random string. Example generators:
#     node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
#     openssl rand -hex 24
#HARNESS_TOKEN=replace-with-long-random-hex

# HARNESS_PORT
#   Alternative port. Dashboard defaults to 4200.
#HARNESS_PORT=4200

# HARNESS_WATCHER_MODE  (P1-3)
#   Controls dedup between SessionWatcher (JSONL tail) and HookRouter
#   (PreToolUse/Stop hooks). Pick ONE source of truth per session.
#
#     auto     (default) start polling; flip to hook-driven when
#              HookRouter.attachExecutor() runs. Best for users running
#              both modes simultaneously — the hook wins.
#     hook     Always hook-driven. Polling still runs so /api/watcher/status
#              stays accurate, but SessionWatcher suppresses pipeline
#              broadcasts. Use when .claude/settings.json hooks are
#              installed and you want the executor to be the only source.
#     watcher  Legacy/fallback. SessionWatcher always broadcasts even if
#              hooks attach. Use when you have not installed hooks.
#     off      No polling. Dashboard relies entirely on hooks.
#HARNESS_WATCHER_MODE=auto
