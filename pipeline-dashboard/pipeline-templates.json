{
  "default": {
    "id": "default",
    "name": "범용 태스크 파이프라인",
    "phases": [
      {
        "id": "A",
        "name": "컨텍스트 수집",
        "label": "Phase A",
        "agent": "claude",
        "allowedTools": ["Read", "Glob", "Grep", "Agent", "TodoWrite"],
        "exitCriteria": [
          { "type": "min-tools-in-phase", "count": 3, "message": "최소 3번 탐색 필요 (Read/Glob/Grep)" }
