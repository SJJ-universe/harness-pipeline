            "sublabel": "프로젝트 분석"
          }
        ]
      },
      {
        "id": "B",
        "name": "계획 수립",
        "label": "Phase B",
        "agent": "claude",
        "allowedTools": ["Read", "Glob", "Grep", "TodoWrite", "Write"],
        "artifactRules": [
          { "toolMatch": "Write", "pathMatch": "plan.*\\.md$", "artifactKey": "plan" }
        ],
        "exitCriteria": [
          { "type": "has-artifact", "key": "plan", "message": "계획 문서(plan*.md)가 Write로 작성되지 않음" }
        ],
        "nodes": [
          {
            "id": "task-planner",
            "icon": "C",
            "iconType": "claude",
            "label": "Claude Code",
            "sublabel": "계획 수립"
          }
        ]
      },
      {
        "id": "C",
        "name": "계획 검토",
        "label": "Phase C",
        "agent": "codex",
        "cycle": true,
        "maxIterations": 3,
        "linkedCycle": "D",
        "timeoutMs": 120000,
        "exitCriteria": [
          { "type": "critique-received", "message": "Codex 비평이 아직 도착하지 않음" }
        ],
        "nodes": [
          {
            "id": "plan-critic",
            "icon": "X",
            "iconType": "codex",
            "label": "Codex CLI",
            "sublabel": "계획 비평"
          }
        ]
      },
      {
        "id": "D",
        "name": "계획 보완",
        "label": "Phase D",
        "agent": "claude",
        "allowedTools": ["Read", "Edit", "Write"],
        "artifactRules": [
          { "toolMatch": "Write", "pathMatch": "plan.*\\.md$", "artifactKey": "plan" },
          { "toolMatch": "Edit", "pathMatch": "plan.*\\.md$", "artifactKey": "plan" }
        ],
        "nodes": [
          {
            "id": "plan-refiner",
            "icon": "C",
            "iconType": "claude",
            "label": "Claude Code",
            "sublabel": "계획 보완"
          }
        ]
      },
      {
        "id": "E",
        "name": "실행",
        "label": "Phase E",
        "agent": "claude",
        "allowedTools": ["Read", "Edit", "Write", "Bash", "Glob", "Grep", "TodoWrite"],
        "exitCriteria": [
          { "type": "files-edited", "min": 1, "message": "실제 파일 수정이 없음" }
        ],
        "nodes": [
          {
            "id": "executor",
            "icon": "⚡",
            "iconType": "emoji",
            "label": "Executor",
            "sublabel": "작업 실행"
          }
        ]
      },
      {
        "id": "F",
        "name": "검증",
        "label": "Phase F",
        "agent": "claude",
        "allowedTools": ["Read", "Bash", "Grep"],
        "exitCriteria": [
          { "type": "bash-ran", "min": 1, "message": "검증 명령(Bash)이 실행되지 않음" },
          { "type": "no-critical-findings", "message": "critical/high finding이 아직 남아있음" }
        ],
        "nodes": [
          {
            "id": "validator",
            "icon": "✓",
            "iconType": "emoji",
            "label": "Validator",
            "sublabel": "결과 검증"
          }
        ]
      },
      {
        "id": "G",
        "name": "최종 비평",
        "label": "Phase G",
        "agent": "codex",
        "allowedTools": [],
        "cycle": true,
        "maxIterations": 2,
        "linkedCycle": "F",
        "exitCriteria": [
          { "type": "critique-received", "message": "Codex 최종 비평이 도착하지 않음" }
        ],
        "nodes": [
          {
            "id": "final-critic",
            "icon": "X",
            "iconType": "codex",
            "label": "Codex CLI",
            "sublabel": "최종 비평"
          }
        ]
      }
    ]
  },
